def collatz_sequence(n):
    """Generate the Collatz sequence starting from n."""
    if n <= 0:
        raise ValueError("Input must be a positive integer.")
    
    sequence = [n]
    while n != 1:
        if n % 2 == 0:
            n = n // 2
        else:
            n = 3 * n + 1
        sequence.append(n)
    return sequence
